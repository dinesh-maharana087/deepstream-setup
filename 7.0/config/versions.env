# Configuration file for DeepStream and related components versions and paths
DEEPSTREAM_VERSION=7.0
DEEPSTREAM_DEB_PATH=/opt/installers/deepstream-7.0_7.0.0-1_amd64.deb

# CUDA version and package version (for apt-get)
CUDA_VERSION=12.2
CUDA_PKG_VERSION=12-2

# TensorRT version and package version (for apt-get)
TENSORRT_VERSION=8.6.1.6
TENSORRT_PKG_VERSION=8.6.1.6-1+cuda12.0

# Python apps requirements
PYTHON_APPS_VERSION=v1.1.11
PYTHON_VERSION=3.10
PYTHON_APPS_ROOT=/opt/nvidia/deepstream-python-apps
# Optional if you pre-stage the wheel locally
PYDS_WHL_PATH=/opt/installers/pyds-1.1.11-py3-none-linux_x86_64.whl
# Optional
INSTALL_CUDA_PYTHON=false

# System requirements
UBUNTU_VERSION=22.04

# Optional: strict install mode (true/false)
STRICT_MODE=false