#!/bin/bash

# DeepStream 8.0 Installation Configuration

_detect_install_user() {
    local candidate

    if [[ -n "${SUDO_USER:-}" && "${SUDO_USER:-}" != "root" ]]; then
        printf '%s\n' "$SUDO_USER"
        return 0
    fi

    if command -v logname >/dev/null 2>&1; then
        candidate="$(logname 2>/dev/null || true)"
        if [[ -n "$candidate" && "$candidate" != "root" ]] && getent passwd "$candidate" >/dev/null 2>&1; then
            printf '%s\n' "$candidate"
            return 0
        fi
    fi

    for candidate in "${LOGNAME:-}" "${USER:-}" "$(id -un 2>/dev/null || true)"; do
        if [[ -n "$candidate" ]] && getent passwd "$candidate" >/dev/null 2>&1; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done

    return 1
}

if [[ -z "${INSTALL_USER:-}" ]]; then
    INSTALL_USER="$(_detect_install_user || true)"
fi

if [[ -z "${INSTALL_USER:-}" ]] || ! getent passwd "$INSTALL_USER" >/dev/null 2>&1; then
    echo "[ERROR] Could not detect the sudo/login user. Set INSTALL_USER explicitly and retry."
    exit 1
fi

export INSTALL_USER
export INSTALL_GROUP="${INSTALL_GROUP:-$(id -gn "$INSTALL_USER" 2>/dev/null || printf '%s\n' "$INSTALL_USER")}"
export INSTALL_HOME="${INSTALL_HOME:-$(getent passwd "$INSTALL_USER" | cut -d: -f6)}"

if [[ -z "$INSTALL_HOME" || ! -d "$INSTALL_HOME" ]]; then
    echo "[ERROR] Could not detect home directory for user: $INSTALL_USER"
    exit 1
fi

export WORK_DIR="${WORK_DIR:-$INSTALL_HOME/deepstream-install}"

export DEEPSTREAM_VERSION="8.0"
export CUDA_VERSION="12.8"
export CUDA_PACKAGE_VERSION="12-8"
export CUDA_APT_PACKAGE="cuda-toolkit-${CUDA_PACKAGE_VERSION}"
export TENSORRT_VERSION="10.9"
export TENSORRT_PACKAGE_VERSION="10.9.0.34-1+cuda12.8"
export PYTHON_APPS_VERSION="v1.2.2"
export CUDA_PYTHON_PACKAGE_SPEC="${CUDA_PYTHON_PACKAGE_SPEC:-cuda-python>=12.8,<12.9}"

export DS_DIR="/opt/nvidia/deepstream/deepstream-${DEEPSTREAM_VERSION}"
export DS_SOURCES_DIR="$DS_DIR/sources"
export PYDS_DIR="$DS_SOURCES_DIR/deepstream_python_apps"

export VENV_PATH="$WORK_DIR/deepstream_venv"

# export GPU_REQUIRED=false
