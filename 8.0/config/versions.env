# DeepStream 8.0 Installation Configuration
# This file defines all version numbers and paths for the automated installer

# Working directory - all installations happen here (not in /opt/nvidia)
# Override with: WORK_DIR=/custom/path bash install_all.sh
export WORK_DIR="${WORK_DIR:=$HOME/deepstream-install}"

# DeepStream version (must be 8.0 for this installer)
export DEEPSTREAM_VERSION="8.0"

# CUDA version
# Format: X-Y for apt installations (e.g., 12-8)
export CUDA_VERSION="12-8"

# TensorRT version with CUDA variant
export TENSORRT_VERSION="10.9.0.34-1+cuda12.8"

# Python DeepStream Apps version (GitHub tag)
export PYTHON_APPS_VERSION="v1.2.2"

# GPU requirement (set to false to skip GPU check during development/testing)
# export GPU_REQUIRED=false